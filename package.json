{
  "name": "btc-puzzle-hunter",
  "version": "2.0.0",
  "description": "Bitcoin Puzzle hunter (multi-worker, checkpointed) + wallet scraper + Telegram notifier",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "btc-hunt": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "auto": "node src/index.js auto",
    "hunt": "node src/index.js hunt",
    "scrape": "node src/index.js scrape",
    "watch": "node src/index.js watch",
    "list": "node src/index.js list",
    "verify": "node src/index.js verify",
    "help": "node src/index.js help",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "bitcoin",
    "puzzle",
    "secp256k1",
    "private-key",
    "bsgs",
    "worker-threads",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "files": [
    "src/",
    "scripts/",
    "data/puzzles.json",
    "config.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@noble/secp256k1": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "bs58check": "^4.0.0"
  }
}
